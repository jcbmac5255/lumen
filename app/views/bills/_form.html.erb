<%# locals: (bill:) %>

<%= styled_form_with model: bill, class: "space-y-4" do |f| %>
  <% if bill.errors.any? %>
    <%= render "shared/form_errors", model: bill %>
  <% end %>

  <section class="space-y-2">
    <%= f.text_field :name, label: "Name", placeholder: "e.g. Rent, Electric, Netflix", required: true, autofocus: bill.new_record? %>
    <%= f.money_field :amount, label: "Amount", required: true, default_currency: Current.family.currency, disable_currency: true %>
    <%
      frequency_options = [
        [ "Weekly", "weekly" ],
        [ "Biweekly (every 2 weeks)", "biweekly" ],
        [ "Monthly", "monthly" ],
        [ "Quarterly (every 3 months)", "quarterly" ],
        [ "Semi-annual (every 6 months)", "semi_annual" ],
        [ "Annual", "annual" ]
      ]
    %>
    <%= f.select :frequency, frequency_options, { label: "Frequency", selected: bill.frequency || "monthly" }, required: true %>
    <%= f.date_field :anchor_date, label: "First / next due date", required: true, hint: "For monthly bills the day-of-month is the recurring due day. For other frequencies, this is when the next occurrence falls." %>
    <%= f.collection_select :category_id,
          Current.family.categories.alphabetically,
          :id, :name,
          { include_blank: "None", label: "Category (optional)" } %>
    <%= f.collection_select :paid_from_account_id,
          Current.family.accounts.visible.where(accountable_type: %w[Depository CreditCard]).alphabetically,
          :id, :name,
          { include_blank: "None (track manually)", label: "Paid from account (optional)", hint: "When marked paid, creates a transaction on this account" } %>
    <%= f.collection_select :paid_to_account_id,
          Current.family.accounts.visible.where(accountable_type: %w[Loan CreditCard OtherLiability]).alphabetically,
          :id, :name,
          { include_blank: "None", label: "Pays toward debt account (optional)", hint: "Set this to pay down a loan or credit card. Marking paid creates a linked transfer between the two accounts." } %>
    <%= f.text_area :notes, label: "Notes (optional)", rows: 3, placeholder: "Account number, payment URL, etc." %>
  </section>

  <section>
    <%= f.submit bill.new_record? ? "Create bill" : "Save" %>
  </section>
<% end %>
