<%# locals: (chat: nil, message_hint: nil) %>

<div id="chat-form" class="relative space-y-2"
     data-controller="chat-mentions chat-attachments">
  <% model = chat && chat.persisted? ? [chat, Message.new] : Chat.new %>

  <%= form_with model: model,
                multipart: true,
                class: "flex lg:flex-col gap-2 bg-container px-2 py-1.5 rounded-full lg:rounded-lg shadow-border-xs",
                data: { chat_target: "form", chat_attachments_target: "form" } do |f| %>

    <%= f.hidden_field :ai_model, value: ENV.fetch("DEFAULT_AI_MODEL", "claude-opus-4-7") %>

    <%= f.file_field :attachments, multiple: true, accept: "image/png,image/jpeg,image/gif,image/webp,application/pdf",
                     class: "hidden",
                     data: { chat_attachments_target: "fileInput", action: "change->chat-attachments#onFiles" } %>

    <div data-chat-attachments-target="previews" class="hidden flex-wrap gap-2 px-1 pt-1"></div>

    <%= f.text_area :content, placeholder: "Ask anything ... (type @ to mention)", value: message_hint,
                  class: "w-full border-0 focus:ring-0 text-sm resize-none px-1 bg-transparent",
                  data: {
                    chat_target: "input",
                    chat_mentions_target: "input",
                    action: "input->chat#autoResize input->chat-mentions#onInput keydown->chat-mentions#onKeyDown keydown->chat#handleInputKeyDown"
                  },
                  rows: 1 %>

    <div class="flex items-center justify-between gap-1">
      <%= icon("plus", as_button: true, data: { action: "click->chat-attachments#pick" }, title: "Attach image or PDF") %>
      <%= icon("arrow-up", as_button: true, type: "submit") %>
    </div>
  <% end %>

  <div data-chat-mentions-target="dropdown"
       class="hidden absolute bottom-full left-0 right-0 mb-2 z-20 max-h-64 overflow-y-auto bg-container rounded-lg shadow-border-xs py-1"></div>

  <p class="text-xs text-secondary">AI responses are informational only and are not financial advice.</p>
</div>
